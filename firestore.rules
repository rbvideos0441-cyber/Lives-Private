rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incomingData() {
      return request.resource.data;
    }

    // --- Active Live Streams ---
    match /lives/{liveId} {
      // Anyone can read active or stored live streams
      allow read: if true;

      // Hosts can create/update their own live stream document
      allow create: if isSignedIn() && 
        incomingData().hostId == request.auth.uid;

      allow update: if isSignedIn() && (
        // Host updating their own stream params
        resource.data.hostId == request.auth.uid ||
        // Viewers incrementing viewersCount or likesCount safely
        (incomingData().diff(resource.data).affectedKeys().hasAny(['viewersCount', 'likesCount']))
      );

      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;

      // --- Nested chat messages subcollection ---
      match /chats/{msgId} {
        allow read: if true;
        allow create: if isSignedIn() && 
          incomingData().userId == request.auth.uid;
        // Admins or hosts can delete messages, but nobody should normally edit
        allow delete: if isSignedIn();
      }

      // --- WebRTC signaling subcollection for streaming ---
      match /viewers/{viewerId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
